# ─────────────────────────────────────────────────────────
# Black Bid Intelligence — Environment Variables
# Copy this file to .env and fill in all required values.
# ─────────────────────────────────────────────────────────

# ── Auth (required) ──────────────────────────────────────
# Generate: openssl rand -base64 32
#NEXTAUTH_SECRET=
NEXTAUTH_SECRET=K3mX9pLqR7vN2wT8dY4sJ6hF1cA0eB5=
# App URL (change for production, e.g. https://bid.black-sa.com)
NEXTAUTH_URL=http://localhost

# ── Database ─────────────────────────────────────────────
# Used by docker-compose. Do NOT set DATABASE_URL manually
# when running via Docker — it is auto-composed from these.
DB_PASSWORD=changeme

# ── Ports (optional overrides) ───────────────────────────
APP_PORT=80
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────
# For local development (outside Docker), set this instead:
# DATABASE_URL=postgresql://blackbid:changeme@localhost:5432/blackbid
# ─────────────────────────────────────────────────────────
